# Copy to .env and adjust. Used by: uvicorn main:app (from server/)
#
# Option A — single URL:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/bvab
#
# Option B — split vars (used if DATABASE_URL is unset). Password can contain special chars.
# PG_USER=n8n
# PG_PASSWORD=your-password
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_DATABASE=n8n
# PG_SSLMODE=require
# Generate for production: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-use-long-random-secret-in-production

# Same as “n8n base URL” in the web UI — used when “Forward n8n via API” is ON (browser → API → n8n, no CORS on n8n).
# N8N_UPSTREAM_URL=http://168.138.44.247:5689

# Postgres for evaluation.auto_test_cases (Test cases → Database panel).
# If omitted, EVALUATION_* uses DATABASE_URL above.
# EVALUATION_DATABASE_URL=postgresql://user:pass@host:5432/dbname
EVALUATION_SCHEMA=evaluation
EVALUATION_TABLE=auto_test_cases
# Same DSN/schema as test cases; table name for nav / CRUD results.
EVALUATION_RESULTS_TABLE=auto_results

# Postgres connect timeout (seconds) — avoids infinite hang if DB is unreachable.
# PG_CONNECT_TIMEOUT=15
